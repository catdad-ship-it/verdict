# Supabase — supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# TMDB — themoviedb.org → Settings → API → v3 auth
TMDB_API_KEY=your_tmdb_api_key

# OMDB — omdbapi.com → get free key (1000 req/day)
OMDB_API_KEY=your_omdb_api_key

# Trakt — trakt.tv/oauth/applications → create an app, use its Client ID
# (not the secret). Powers the "Trending Now" shelf. Optional: without
# this set, trending falls back to the old Reddit-scrape approach.
TRAKT_CLIENT_ID=your_trakt_client_id

# Fanart.tv — fanart.tv/get-an-api-key (free, personal use). Powers the
# transparent title-logo art in the title detail modal. Optional: without
# this set, the modal just shows the plain text title.
FANART_API_KEY=your_fanart_api_key

# Does The Dog Die — doesthedogdie.com/profile → "Get an API key" (free
# tier). Powers the "Content notes" section in the title detail modal.
# Optional: without this set, that section just doesn't render.
DDD_API_KEY=your_doesthedogdie_api_key
